<script>
function verificar() {
    let texto = document.getElementById("texto").value.toLowerCase().trim();
    let resultado = document.getElementById("resultado");
    let explicacion = document.getElementById("explicacion");

    // Si no hay texto o es muy corto
    if (texto.length < 10) {
        resultado.innerHTML = "⚪ INSUFICIENTE";
        resultado.style.color = "gray";
        explicacion.innerHTML = "El texto es muy corto o no tiene suficiente información para verificar.";
        return;
    }

    let puntosFalso = 0;
    let puntosDudoso = 0;

    // Palabras sospechosas (fake news)
    if (texto.includes("urgente") || texto.includes("compártelo") || texto.includes("última hora")) {
        puntosFalso++;
    }

    if (texto.includes("dicen que") || texto.includes("no confirmado") || texto.includes("al parecer")) {
        puntosDudoso++;
    }

    if (texto.includes("fuente desconocida") || texto.includes("me dijeron")) {
        puntosFalso++;
    }

    // Si no menciona ninguna fuente
    if (!texto.includes("fuente") && !texto.includes("según") && !texto.includes("ministerio")) {
        puntosDudoso++;
    }

    // Clasificación final
    if (puntosFalso >= 2) {
        resultado.innerHTML = "🔴 FALSO";
        resultado.style.color = "red";
        explicacion.innerHTML = "El contenido presenta señales claras de desinformación: lenguaje alarmista y falta de fuentes confiables.";
    } 
    else if (puntosDudoso >= 1) {
        resultado.innerHTML = "🟡 DUDOSO";
        resultado.style.color = "orange";
        explicacion.innerHTML = "La información no es completamente confiable. Se recomienda verificar en fuentes oficiales o medios reconocidos.";
    } 
    else {
        resultado.innerHTML = "🟢 POSIBLEMENTE VERDADERO";
        resultado.style.color = "green";
        explicacion.innerHTML = "El contenido no presenta señales claras de desinformación, pero siempre es importante confirmar con fuentes oficiales.";
    }
}
</script>
